{
    "private": true,
    "scripts": {
        "dev": "vite --host=0.0.0.0 --port=5173 --clearScreen=false",
        "dev:debug": "vite --host=0.0.0.0 --port=5173 --debug",
        "dev:no-cache": "vite --host=0.0.0.0 --port=5173 --force",
        "build": "vite build --mode=production",
        "build:analyze": "vite build --mode=production --ssrManifest",
        "preview": "vite preview --host=0.0.0.0 --port=4173",
        "build:capacitor": "vite build --config vite.config.capacitor.js --mode capacitor",
        "dev:capacitor": "vite --config vite.config.capacitor.js --mode capacitor",
        "build:capacitor:dev": "vite build --config vite.config.capacitor.js --mode=development",
        "cap:sync": "npx cap sync",
        "cap:open:android": "npx cap open android",
        "cap:open:ios": "npx cap open ios",
        "cap:copy": "npx cap copy",
        "test:php": "php artisan test",
        "test:php:unit": "php artisan test --testsuite=Unit",
        "test:js": "cd tests-js && npx codeceptjs run",
        "test:vitest": "vitest run --config vitest.config.js",
        "test:vitest:watch": "vitest"
    },
    "devDependencies": {
        "@codeceptjs/configure": "^1.0.6",
        "@popperjs/core": "^2.11.6",
        "@rollup/rollup-linux-x64-gnu": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.4",
        "@vue/test-utils": "^2.4.6",
        "axios": "^1.1.2",
        "bootstrap": "^5.3.7",
        "codeceptjs": "^3.7.7",
        "jest": "^29.7.0",
        "jsdom": "^29.0.2",
        "laravel-vite-plugin": "^2.1.0",
        "lodash": "^4.17.19",
        "luxon": "^3.4.4",
        "playwright": "^1.58.2",
        "postcss": "^8.1.14",
        "rollup": "^4.0.0",
        "sass": "^1.97.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.4",
        "vue": "^3.2.36"
    },
    "dependencies": {
        "@capacitor-community/electron": "^5.0.1",
        "@capacitor/android": "^8.4.0",
        "@capacitor/cli": "^8.4.0",
        "@capacitor/core": "^8.4.0",
        "@capacitor/ios": "^8.4.0",
        "@capacitor/preferences": "^8.0.1",
        "esbuild": "^0.28.0",
        "jdenticon": "^3.3.0",
        "mitt": "^3.0.1",
        "pinia": "^2.0.34",
        "relation-graph-vue3": "^2.2.11",
        "swiper": "^12.1.4",
        "uuid": "^14.0.0",
        "vue-i18n": "^11.1.1",
        "vue-loader": "^17.0.1",
        "vue-router": "^4.5.1"
    },
    "jest": {
        "testEnvironment": "node",
        "watchman": false,
        "testMatch": [
            "<rootDir>/resources/js/__tests__/**/*.test.js"
        ],
        "verbose": true,
        "transform": {},
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        }
    }
}
