{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "vite build",
        "test": "npm run test:php && npm run test:js",
        "test:php": "vendor/bin/phpunit",
        "test:js": "node --experimental-vm-modules node_modules/jest/bin/jest.js --colors",
        "test:js:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
    },
    "devDependencies": {
        "@popperjs/core": "^2.11.6",
        "jest": "^29.7.0",
        "@vitejs/plugin-vue": "^4.0.0",
        "axios": "^1.1.2",
        "bootstrap": "^5.3.7",
        "luxon": "^3.4.4",
        "laravel-vite-plugin": "^0.7.2",
        "lodash": "^4.17.19",
        "postcss": "^8.1.14",
        "sass": "1.49.11",
        "vite": "^4.5.9",
        "vue": "^3.2.36"
    },
    "dependencies": {
        "mitt": "^3.0.1",
        "pinia": "^2.0.34",
        "uuid": "^11.1.0",
        "vue-i18n": "^11.1.1",
        "vue-loader": "^17.0.1",
        "vue-router": "^4.5.1"
    },
    "jest": {
        "testEnvironment": "node",
        "watchman": false,
        "testMatch": [
            "<rootDir>/resources/js/__tests__/**/*.test.js"
        ],
        "verbose": true,
        "transform": {},
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        }
    }
}
