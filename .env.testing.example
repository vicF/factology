APP_NAME="Factology Testing"
APP_ENV=testing
APP_KEY=base64:xWDhxwm+lMZgEe7J5WgMvqURtvFO/e0yxL26m/ytyzU=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=single

# Database for GitHub Actions - these match the service container
DB_CONNECTION=pgsql
DB_HOST=factology-postgres
DB_PORT=5432
DB_DATABASE=factology_tmp_test
DB_USERNAME=factology_test
DB_PASSWORD=test_pass

# Cache and session for testing
CACHE_DRIVER=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

# Sanctum/Session (Crucial for Vue API calls)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,::1,172.17.0.0/16,172.18.0.0/16,172.19.0.0/16,172.20.0.0/16
SESSION_DOMAIN=localhost

# Vite Configuration
VITE_HOST=localhost
VITE_PORT=5173
VITE_SOURCEMAP=true
ASSET_URL=http://localhost:8000

# Pusher/Echo (if used in Vue)
PUSHER_APP_ID=local-testing-id
PUSHER_APP_KEY=local-testing-key
PUSHER_APP_SECRET=local-testing-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# Vite Pusher Variables (Your Vue3 needs these)
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Broadcasting (if using Echo)
BROADCAST_CONNECTION=pusher

# Mail Testing
MAIL_MAILER=array
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Codeception
TESTED_HOST=http://localhost:8005
DOCKER_HOST=host.docker.internal
FIREFOX_ARGS=
#CHROME_ARGS="--headless,"
# put some option here for correct parsing
CHROME_ARGS=--disable-extensions
BROWSER=chrome
# Host where browser for automated tests is located. Use localhost for browser inside docker container.
# Or host.docker.internal for browser on your host machine
#BROWSER_HOST = localhost
TEST_BROWSER_HOST=host.docker.internal
# number of retries (total attempts = 4)
RETRY_COUNT=3
# milliseconds between retries
RETRY_DELAY=500
