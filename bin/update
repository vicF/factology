#!/usr/bin/env bash
# ================================================================
#  Factology — one-command update
#  Pulls latest code and restarts containers with a fresh build.
#
#  Usage:
#    ./bin/update
# ================================================================
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

COLOR_RESET='\033[0m'; COLOR_GREEN='\033[0;32m'; COLOR_YELLOW='\033[1;33m'; COLOR_CYAN='\033[0;36m'; COLOR_BOLD='\033[1m'
step() { echo -e "\n${COLOR_CYAN}==>${COLOR_RESET} ${COLOR_BOLD}$1${COLOR_RESET}"; }
ok()   { echo -e "  ${COLOR_GREEN}✓${COLOR_RESET} $1"; }

# ── 1. Pull latest code ─────────────────────────────────────────────────────────
step "Pulling latest code"

cd "$REPO_DIR"
git pull
ok "Code updated"

# ── 2. Rebuild and restart ──────────────────────────────────────────────────────
step "Rebuilding and restarting containers"

docker compose up -d --build
ok "Containers started"

# ── 3. Show status ──────────────────────────────────────────────────────────────
step "Status"
docker compose ps

echo ""
echo -e "${COLOR_GREEN}${COLOR_BOLD}  Update complete!${COLOR_RESET}"
