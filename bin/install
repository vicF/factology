#!/usr/bin/env bash
# ================================================================
#  Factology — one-command install
#  Installs Docker, clones the project, and starts everything.
#
#  Usage:
#    curl -fsSL https://raw.githubusercontent.com/vicF/factology/main/bin/install | bash
#    # or:
#    wget -qO- https://raw.githubusercontent.com/vicF/factology/main/bin/install | bash
# ================================================================
set -euo pipefail

REPO_URL="https://github.com/vicF/factology.git"
REPO_BRANCH="main"
INSTALL_DIR="${1:-$HOME/factology}"

COLOR_RESET='\033[0m'; COLOR_GREEN='\033[0;32m'; COLOR_YELLOW='\033[1;33m'; COLOR_CYAN='\033[0;36m'; COLOR_BOLD='\033[1m'
step() { echo -e "\n${COLOR_CYAN}==>${COLOR_RESET} ${COLOR_BOLD}$1${COLOR_RESET}"; }
ok()   { echo -e "  ${COLOR_GREEN}✓${COLOR_RESET} $1"; }

# ── Check prerequisites ────────────────────────────────────────────────────────
step "Checking system requirements"

if ! command -v docker &>/dev/null; then
  echo "  Docker not found. Installing..."
  curl -fsSL https://get.docker.com | sh
  sudo usermod -aG docker "$USER"
  DOCKER_CMD="sudo docker"
  ok "Docker installed (log out/in for passwordless use)"
else
  ok "Docker $(docker --version | cut -d' ' -f3 | tr -d ',')"
  DOCKER_CMD="docker"
fi

if ! docker compose version &>/dev/null; then
  echo "  Docker Compose plugin not found."
  echo "  See: https://docs.docker.com/compose/install/"
  exit 1
fi
ok "Docker Compose available"

# ── Clone / pull ───────────────────────────────────────────────────────────────
step "Downloading Factology"

if [[ -d "$INSTALL_DIR/.git" ]]; then
  echo "  Updating existing installation..."
  cd "$INSTALL_DIR" && git pull
else
  cd "$(dirname "$INSTALL_DIR")" 2>/dev/null || mkdir -p "$(dirname "$INSTALL_DIR")"
  git clone --branch "$REPO_BRANCH" "$REPO_URL" "$INSTALL_DIR"
fi
cd "$INSTALL_DIR"
ok "Code ready at $INSTALL_DIR"

# ── .env (only if it doesn't exist) ────────────────────────────────────────────
step "Setting up environment"

if [[ ! -f .env ]]; then
  if [[ -f .env.example ]]; then
    cp .env.example .env
    # Production-safe defaults
    sed -i 's|^APP_ENV=.*|APP_ENV=production|' .env
    sed -i 's|^APP_DEBUG=.*|APP_DEBUG=false|' .env
    sed -i 's|^DB_HOST=.*|DB_HOST=postgres|' .env
    sed -i 's|^DB_PORT=.*|DB_PORT=5432|' .env
    sed -i 's|^DB_CONNECTION=.*|DB_CONNECTION=pgsql|' .env
    ok ".env created with production defaults (edit if needed)"
  else
    echo "  No .env.example found. Create .env manually."
    exit 1
  fi
else
  ok ".env already exists"
fi

# ── Launch ─────────────────────────────────────────────────────────────────────
step "Starting containers (first build takes a few minutes)"

$DOCKER_CMD compose up -d
ok "Containers started"

# ── Done ───────────────────────────────────────────────────────────────────────
echo ""
echo -e "${COLOR_GREEN}${COLOR_BOLD}  Factology is running!${COLOR_RESET}"
echo ""
echo "  Open:   http://localhost:8003"
echo ""
echo "  Manage:"
echo "    Stop:    cd $INSTALL_DIR && ${DOCKER_CMD} compose down"
echo "    Update:  cd $INSTALL_DIR && git pull && ${DOCKER_CMD} compose up -d --build"
echo "    Logs:    ${DOCKER_CMD} compose logs -f"
echo ""
echo "  (If you were added to the docker group, log out and back in.)"
echo ""
